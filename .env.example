# Docker database URL.

# If running the backend outside Docker, change "db" to "localhost".

DATABASE_URL=postgresql://healthcare_user:healthcare_pass@db:5432/healthcare_db

SECRET_KEY=replace_with_secure_secret

# Gemini API configuration.

# Do not put your real key in this example file.

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_API_URL=

# Optional Zep memory integration.

# Leave ZEP_API_KEY empty if you do not want to use Zep.

ZEP_API_KEY=
ZEP_USER_ID=healthcare-demo-user
ZEP_USER_EMAIL=[healthcare.demo@example.com](mailto:healthcare.demo@example.com)
ZEP_USER_FIRST_NAME=Healthcare
ZEP_USER_LAST_NAME=Demo

PYTHON_ENV=development
